# Copy to Vercel Project → Settings → Environment Variables (Production)
# Do NOT commit real secrets.

NODE_ENV=production

# MongoDB Atlas — allow Vercel IPs or 0.0.0.0/0 in Atlas Network Access
DATABASE_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/procurement?retryWrites=true&w=majority

# Generate: openssl rand -base64 48
JWT_SECRET=

# Comma-separated allowed browser origins
CORS_ORIGINS=https://your-app.vercel.app
FRONTEND_URL=https://your-app.vercel.app

# Public API URL (your Vercel deployment URL)
BACKEND_PUBLIC_URL=https://your-app.vercel.app

# Zoho — add production redirect in API Console AND here
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://your-app.vercel.app/api/zoho/callback
ZOHO_REDIRECT_URI_PRODUCTION=https://your-app.vercel.app/api/zoho/callback
ZOHO_REDIRECT_URI_LOCAL=http://localhost:5001/api/zoho/callback
# Multi-DC: no ZOHO_REGION needed — users sign in via global Zoho OAuth

# Optional
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_DEPLOYMENT_NAME=
# AZURE_API_VERSION=2024-02-15-preview
