# Server (local development)
PORT=5001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars-for-prod

# CORS — comma-separated; defaults include localhost:3000
# CORS_ORIGINS=http://localhost:3000

# MongoDB (required)
DATABASE_URL="mongodb://127.0.0.1:27017/procurement"

# Frontend URL (OAuth redirect after connect)
FRONTEND_URL=http://localhost:3000

# --- Zoho Books (admin only — end users just click "Connect with Zoho") ---
# Create app at https://api-console.zoho.com/ and enable Multi-DC in the console.
# Users in India/EU/etc. are routed automatically; no ZOHO_REGION needed in the UI.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:5001/api/zoho/callback
ZOHO_REDIRECT_URI_LOCAL=http://localhost:5001/api/zoho/callback
ZOHO_REDIRECT_URI_PRODUCTION=https://your-api.vercel.app/api/zoho/callback
BACKEND_PUBLIC_URL=http://localhost:5001
# Optional: per-region credentials if Multi-DC is not enabled in Zoho console
# ZOHO_CLIENT_ID_IN=  ZOHO_CLIENT_SECRET_IN=
# Optional: paste a purchase item ID from Zoho Books → Items (type: Purchases)
# ZOHO_DEFAULT_PURCHASE_ITEM_ID=
# ZOHO_CLIENT_ID_EU=  ZOHO_CLIENT_SECRET_EU=

# Local dev: skip SMS OTP when Twilio is not configured (default behavior)
SKIP_SMS_VERIFICATION=true

# Optional: Twilio SMS verification
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Optional: Azure OpenAI for AI Insights
# AZURE_OPENAI_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_DEPLOYMENT_NAME=
# AZURE_API_VERSION=2024-02-15-preview
